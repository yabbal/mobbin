{
	"name": "mobbin-cli",
	"version": "1.0.0",
	"description": "CLI for Mobbin - browse and download design references",
	"author": "yabbal",
	"license": "MIT",
	"type": "module",
	"bin": {
		"mobbin": "./dist/index.js"
	},
	"files": ["dist", "README.md", "LICENSE"],
	"publishConfig": {
		"provenance": true,
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check src/",
		"check": "tsc --noEmit",
		"clean": "rm -rf dist .turbo",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"mobbin-sdk": "workspace:*",
		"citty": "^0.1.6",
		"@clack/prompts": "^0.9.1",
		"cli-table3": "^0.6.5"
	},
	"devDependencies": {
		"@types/node": "^22.15.3",
		"tsup": "^8.4.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/yabbal/mobbin"
	}
}
